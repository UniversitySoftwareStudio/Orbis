# ==========================================
# Orbis - Environment Variables
# Copy this file to .env and fill in the values
# ==========================================

# --- Database Configuration ---
DB_USER=admin
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orbisdb

# Optional: Provide a full DATABASE_URL instead of individual DB_* vars
# DATABASE_URL=postgresql://user:password@host:port/dbname

# --- JWT Authentication ---
JWT_SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Embedding Service Configuration ---
# Provider options: 'tei', 'ollama', 'local'
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=384

# TEI (Text Embeddings Inference) Settings
EMBEDDING_SERVICE_URL=http://localhost:7860
# Optional: Use TEI_URL instead of EMBEDDING_SERVICE_URL
# TEI_URL=http://localhost:7860
# Optional: Multiple TEI endpoints (comma-separated)
# TEI_URLS=http://localhost:7860,http://localhost:7861

# Ollama Settings (if EMBEDDING_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=all-minilm

LOCAL_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 # Hugging Face model name for local embeddings

# --- LLM Provider Configuration ---
# Choose between 'groq' or 'gemini'
LLM_PROVIDER=groq

# Groq Settings (if LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini Settings (if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- Reranker Configuration ---
# Required for the reranking pipeline
JINA_API_KEY=your_jina_api_key_here