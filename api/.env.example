# ==========================================
# Orbis - Environment Variables
# Copy this file to .env and fill in the values
# ==========================================

# --- Database Configuration ---
DB_USER=admin
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orbisdb

# Optional: Provide a full DATABASE_URL instead of individual DB_* vars
# DATABASE_URL=postgresql://user:password@host:port/dbname

# --- JWT Authentication ---
JWT_SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Embedding Service Configuration ---
# Provider options: 'tei', 'ollama', 'local'
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=384

# TEI (Text Embeddings Inference) Settings
EMBEDDING_SERVICE_URL=http://localhost:7860
# Optional: Use TEI_URL instead of EMBEDDING_SERVICE_URL
# TEI_URL=http://localhost:7860
# Optional: Multiple TEI endpoints (comma-separated)
# TEI_URLS=http://localhost:7860,http://localhost:7861

# Ollama Settings (if EMBEDDING_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=all-minilm

LOCAL_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 # Hugging Face model name for local embeddings

# --- LLM Provider Configuration ---
# Choose between 'groq' or 'gemini'
LLM_PROVIDER=groq

# Groq Settings (if LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini Settings (if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- Reranker Configuration ---
# Required for the reranking pipeline
JINA_API_KEY=your_jina_api_key_here

# --- Logging and Debugging ---
# Set log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=DEBUG

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAG — RETRIEVAL SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable RAG debugging (1 to enable, 0 to disable)
RAG_DEBUG=1

# Number of candidate documents fetched from the vector store before reranking.
# In single-intent mode this value is used as-is; in multi-intent (parallel) mode
# each intent fetches RAG_TOP_K / 2 docs. Higher = more recall, slower rerank.
# Recommended: 20–40.
RAG_TOP_K=30

# Number of documents kept after reranking and passed to the LLM as context.
# In single-intent mode this value is used as-is; in multi-intent (parallel) mode
# each intent contributes RAG_FINAL_K / 2 docs. Higher = more context, but
# increases prompt size and may reduce focus.
RAG_FINAL_K=10

# Minimum vector similarity score (0.0–1.0) for a document to be considered.
# Set to 0.0 to disable threshold filtering entirely.
RAG_SCORE_THRESHOLD=0.0

# Enable adaptive per-intent fetch-limit reduction when multiple intents are
# routed in the same query (true/false). When false, every intent always fetches
# RAG_TOP_K docs regardless of how many intents were returned by the router.
# Disable if you need strict sequential execution for debugging.
RAG_PARALLEL_MODE=true

# Threshold for switching to compact CSV format when SQL intent is present.
# If a SQL query returns more than this many docs, output switches to CSV.
RAG_COMPACT_SQL_THRESHOLD=5

# Threshold for switching to compact CSV format regardless of intent type.
# Prevents oversized context when many documents are retrieved.
RAG_COMPACT_DOC_THRESHOLD=40

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAG — RERANKER SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable or disable Jina reranking. If disabled, top RAG_FINAL_K docs
# from the vector search are used directly without reranking.
RAG_RERANK_ENABLED=true

# Jina reranker model name.
RAG_RERANK_MODEL=jina-reranker-v2-base-multilingual

# How many top documents the reranker returns. Should equal RAG_FINAL_K
# unless you want to rerank more and truncate afterwards.
RAG_RERANK_TOP_N=5

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAG — LLM SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Maximum tokens the LLM can generate in a single response.
RAG_LLM_MAX_TOKENS=1024

# Stream the LLM response token-by-token to the frontend (true/false).
RAG_STREAM_ENABLED=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAG — CONTEXT SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Maximum character length of the context block fed to the LLM.
# Prevents exceeding the model's context window on large result sets.
# Set to 0 to disable truncation entirely.
RAG_MAX_CONTEXT_CHARS=12000